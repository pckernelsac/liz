# Copia este archivo como .env y completa los valores.
# EasyPanel: define estas variables en "Environment" del servicio.

# === Obligatorias ===

# Clave para firmar cookies de sesión. Genera una nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ¡No uses el valor de ejemplo en producción!
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-de-64-caracteres

# Cadena de conexión a PostgreSQL.
# En EasyPanel apunta al servicio de Postgres dentro de la misma red:
#   postgresql://<user>:<password>@<service-name>:5432/<dbname>
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sorteo

# === Opcionales (tienen defaults sensatos) ===

# Host de bind (0.0.0.0 para aceptar conexiones externas dentro del contenedor)
HOST=0.0.0.0

# Puerto interno del contenedor (EasyPanel lo mapea al dominio público)
PORT=5000

# DEBUG en producción debe ser False. Activa el reload de uvicorn y debug de FastAPI.
DEBUG=False
