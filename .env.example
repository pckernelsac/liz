# Copia este archivo como .env y completa los valores.
# EasyPanel: define estas variables en "Environment" del servicio.

# === Obligatorias ===

# Clave para firmar cookies de sesión. Genera una nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ¡No uses el valor de ejemplo en producción!
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-de-64-caracteres

# Cadena de conexión a PostgreSQL.
# Formatos aceptados por psycopg2:
#   postgresql://<user>:<password>@<host>:5432/<dbname>
#   postgres://<user>:<password>@<host>:5432/<dbname>       (alias)
#
# En EasyPanel, copia la cadena EXACTA que te muestra el servicio de Postgres
# (Connection Details → Internal URL). Ejemplo típico de EasyPanel:
#   postgres://postgres:XXXXXXXX@<app>_bd-sorteo:5432/<dbname>?sslmode=disable
#
# Nota: dentro de la red interna de EasyPanel el tráfico ya es privado,
# por eso se usa sslmode=disable. No lo actives si el servicio lo rechaza.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sorteo

# === Opcionales (tienen defaults sensatos) ===

# Host de bind (0.0.0.0 para aceptar conexiones externas dentro del contenedor)
HOST=0.0.0.0

# Puerto interno del contenedor (EasyPanel lo mapea al dominio público)
PORT=5000

# DEBUG en producción debe ser False. Activa el reload de uvicorn y debug de FastAPI.
DEBUG=False

# Panel administrativo (ruta /admin/login): usuario admin, contraseña admin123
# (definido en app.py; cámbialo en el código si necesitas otra credencial).
